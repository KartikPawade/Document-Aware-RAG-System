# ─────────────────────────────────────────────────────────────
# Advanced RAG System — Environment Configuration
# Copy this file to .env and fill in required values.
# ─────────────────────────────────────────────────────────────

# ── Required ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production

# ── OpenAI Models ────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENRICHMENT_MODEL=gpt-4o-mini

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_PREFER_GRPC=false
DENSE_VECTOR_SIZE=1024           # BGE-M3 output dim

# ── Embeddings (BGE-M3, self-hosted) ─────────────────────────
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu             # cpu | cuda | mps
EMBEDDING_BATCH_SIZE=32

# ── Reranker (BGE-Reranker-v2-m3, self-hosted) ───────────────
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=5
RERANKER_BATCH_SIZE=16

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb
POSTGRES_DSN=postgresql://raguser:ragpassword@localhost:5432/ragdb

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
QUERY_CACHE_TTL=1800             # 30 minutes
HOT_CHUNK_TTL=300                # 5 minutes

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false
MINIO_BUCKET_DOCUMENTS=rag-documents

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INGESTION=rag.ingestion.documents
KAFKA_CONSUMER_GROUP=rag-ingestion-group

# ── Ingestion Pipeline ────────────────────────────────────────
CHILD_CHUNK_SIZE=400             # tokens
PARENT_CHUNK_SIZE=1500           # tokens
CHUNK_OVERLAP=50                 # tokens
ENRICHMENT_ENABLED=true
ENRICHMENT_BATCH_SIZE=10         # concurrent LLM calls

# ── Retrieval ─────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
MIN_SIMILARITY_SCORE=0.72        # below this → "no relevant info"
MAX_CONTEXT_TOKENS=4000

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ── Evaluation (RAGAS) ────────────────────────────────────────
RAGAS_ENABLED=true
RAGAS_SAMPLE_RATE=0.01           # 1% of production queries
